{
  "name": "py3pkg",
  "image": "ghcr.io/astral-sh/uv:debian-slim",
  "postCreateCommand": "uv self version",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--rm",
    "--name", "media2ascii"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.python",
        "GitHub.vscode-github-actions",
        "tamasfe.even-better-toml"
      ],
      "settings": {}
    }
  },
